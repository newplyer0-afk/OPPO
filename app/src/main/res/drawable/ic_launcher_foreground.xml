<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer Glow Circle representing TimeFlow -->
    <path
        android:strokeWidth="3"
        android:strokeColor="#3300FFCC"
        android:pathData="M54,54m-28,0a28,28 0,1 1,56 0a28,28 0,1 1,-56 0" />
        
    <!-- Main Premium Outer Ring -->
    <path
        android:strokeWidth="2.5"
        android:pathData="M54,26 C69.46,26 82,38.54 82,54 C82,69.46 69.46,82 54,82 C38.54,82 26,69.46 26,54"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="26"
                android:startY="26"
                android:endX="82"
                android:endY="82"
                android:type="linear">
                <item android:color="#00FFCC" android:offset="0.0" />
                <item android:color="#FED766" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Hourglass Flow Graphic -->
    <path
        android:pathData="M38,36 L70,36 L57,51 L57,57 L70,72 L38,72 L51,57 L51,51 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="38"
                android:startY="36"
                android:endX="70"
                android:endY="72"
                android:type="linear">
                <item android:color="#CCFFFFFF" android:offset="0.0" />
                <item android:color="#CC00FFCC" android:offset="0.5" />
                <item android:color="#CCFED766" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Center flow dot -->
    <path
        android:fillColor="#00FFCC"
        android:pathData="M54,54m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0" />

    <!-- Clock ticking details -->
    <path
        android:pathData="M54,18 L54,22 M54,86 L54,90 M18,54 L22,54 M86,54 L90,54"
        android:strokeWidth="2"
        android:strokeColor="#66FFFFFF"
        android:strokeLineCap="round" />
